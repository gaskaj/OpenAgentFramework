FROM golang:1.25-alpine AS builder

RUN apk --no-cache add git

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG VERSION=dev
RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags "-X github.com/gaskaj/OpenAgentFramework/internal/version.Version=${VERSION} \
              -X github.com/gaskaj/OpenAgentFramework/internal/version.Commit=$(git rev-parse --short HEAD 2>/dev/null || echo unknown) \
              -X github.com/gaskaj/OpenAgentFramework/internal/version.BuildDate=$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    -o controlplane ./cmd/controlplane

FROM alpine:3.20

RUN apk --no-cache add ca-certificates tzdata curl unzip && \
    ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ]; then NGROK_ARCH="arm64"; elif [ "$ARCH" = "x86_64" ]; then NGROK_ARCH="amd64"; else NGROK_ARCH="amd64"; fi && \
    curl -sL "https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-${NGROK_ARCH}.tgz" -o /tmp/ngrok.tgz && \
    tar xzf /tmp/ngrok.tgz -C /usr/local/bin && \
    rm /tmp/ngrok.tgz && \
    apk del curl unzip
WORKDIR /app
COPY --from=builder /app/controlplane .

EXPOSE 8080
ENTRYPOINT ["./controlplane"]
CMD ["--config", "/app/config.yaml"]
